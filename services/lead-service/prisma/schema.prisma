datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LeadSource {
  WEBSITE
  REFERRAL
  COLD_CALL
  EMAIL
  OTHER
}

enum LeadStatus {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  DELETED
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
}

enum FollowUpStatus {
  PENDING
  DONE
  MISSED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
}

model User {
  id                   String             @id @default(uuid())
  name                 String
  email                String             @unique
  password             String
  role                 UserRole
  teamId               String?
  team                 Team?              @relation("TeamMembers", fields: [teamId], references: [id])
  managedTeams         Team[]             @relation("TeamManager")
  assignedLeads        Lead[]
  createdPipelines     Pipeline[]
  changedDealHistories DealStageHistory[]
  followups            FollowUp[]
  callLogs             CallLog[]
  notifications        Notification[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([role])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  managerId String
  manager   User     @relation("TeamManager", fields: [managerId], references: [id])
  members   User[]   @relation("TeamMembers")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id           String       @id @default(uuid())
  name         String
  company      String
  phone        String
  email        String
  source       LeadSource
  status       LeadStatus
  score        Int          @default(0)
  assignedToId String
  assignedTo   User         @relation(fields: [assignedToId], references: [id])
  deals        Deal[]
  followups    FollowUp[]
  callLogs     CallLog[]
  aiScore      AILeadScore?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model Pipeline {
  id        String          @id @default(uuid())
  name      String
  stages    PipelineStage[]
  createdBy String
  creator   User            @relation(fields: [createdBy], references: [id])
  deals     Deal[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PipelineStage {
  id            String             @id @default(uuid())
  name          String
  order         Int
  color         String
  pipelineId    String
  pipeline      Pipeline           @relation(fields: [pipelineId], references: [id])
  deals         Deal[]             @relation("CurrentStage")
  fromHistories DealStageHistory[] @relation("FromStage")
  toHistories   DealStageHistory[] @relation("ToStage")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Deal {
  id                String             @id @default(uuid())
  leadId            String
  lead              Lead               @relation(fields: [leadId], references: [id])
  pipelineId        String
  pipeline          Pipeline           @relation(fields: [pipelineId], references: [id])
  currentStageId    String
  currentStage      PipelineStage      @relation("CurrentStage", fields: [currentStageId], references: [id])
  value             Decimal            @db.Decimal(12, 2)
  probability       Int
  expectedCloseDate DateTime?
  stageHistories    DealStageHistory[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([leadId])
  @@index([currentStageId])
  @@index([createdAt])
}

model DealStageHistory {
  id          String        @id @default(uuid())
  dealId      String
  deal        Deal          @relation(fields: [dealId], references: [id])
  fromStageId String
  fromStage   PipelineStage @relation("FromStage", fields: [fromStageId], references: [id])
  toStageId   String
  toStage     PipelineStage @relation("ToStage", fields: [toStageId], references: [id])
  changedBy   String
  changer     User          @relation(fields: [changedBy], references: [id])
  changedAt   DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([dealId])
}

model FollowUp {
  id             String         @id @default(uuid())
  leadId         String
  lead           Lead           @relation(fields: [leadId], references: [id])
  assignedToId   String
  assignedTo     User           @relation(fields: [assignedToId], references: [id])
  scheduledAt    DateTime
  type           FollowUpType
  status         FollowUpStatus
  notes          String
  reminderSentAt DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([leadId])
  @@index([assignedToId])
  @@index([status])
  @@index([scheduledAt])
}

model Campaign {
  id             String           @id @default(uuid())
  name           String
  subject        String
  templateId     String
  template       CampaignTemplate @relation(fields: [templateId], references: [id])
  status         CampaignStatus
  recipientCount Int              @default(0)
  scheduledAt    DateTime
  emailLogs      EmailLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

model CampaignTemplate {
  id        String     @id @default(uuid())
  name      String
  subject   String
  content   String
  campaigns Campaign[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model EmailLog {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  recipient  String
  sentAt     DateTime @default(now())
  openedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([campaignId])
}

model CallLog {
  id           String   @id @default(uuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id])
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  duration     Int
  recordingUrl String?
  notes        String
  calledAt     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([leadId])
  @@index([userId])
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([createdAt])
}

model AILeadScore {
  id          String   @id @default(uuid())
  leadId      String   @unique
  lead        Lead     @relation(fields: [leadId], references: [id])
  score       Int
  signals     String[]
  confidence  Decimal  @db.Decimal(5, 2)
  generatedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
}

model AuditLog {
  id          String      @id @default(uuid())
  entity      String
  entityId    String
  action      AuditAction
  performedBy String
  payload     Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([entity, entityId])
  @@index([performedBy])
  @@index([createdAt])
}
